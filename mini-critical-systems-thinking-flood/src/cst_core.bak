#include "cst_core.h"
#include <stdlib.h>
#include <string.h>
#include <stdio.h>
#include <math.h>

/* ==============================================================
 * Critical Systems Thinking — Core Implementation
 *
 * Implements stakeholder analysis, metaphor assessment, methodology
 * selection, problem context classification, and boundary critique.
 * ============================================================== */

CSTSystem* cst_create(const char* name) {
    CSTSystem* s = calloc(1, sizeof(CSTSystem));
    if (!s) return NULL;
    s->name = strdup(name);
    s->time = 0.0;
    s->iteration = 0;
    s->current_phase = CST_CREATIVITY;
    s->phase_progress = 0.0;
    s->systemicity_score = 0.5;
    s->pluralism_index = 0.0;
    s->critical_depth = 0.3;
    s->emancipatory_index = 0.0;
    s->stakeholders = malloc(CST_MAX_STAKEHOLDERS * sizeof(CSTStakeholder));
    s->metaphors = malloc(CST_MAX_METAPHORS * sizeof(CSTMetaphorLens));
    s->methodologies = malloc(CST_MAX_METHODOLOGIES * sizeof(CSTMethodology));
    return s;
}

void cst_free(CSTSystem* s) {
    if (!s) return;
    free(s->name);
    for (int i = 0; i < s->n_stakeholders; i++) { free(s->stakeholders[i].name); free(s->stakeholders[i].role); }
    free(s->stakeholders);
        free(s->metaphors[i].name);
        for (int j = 0; j < s->metaphors[i].n_insights; j++) free(s->metaphors[i].key_insights[j]);
        free(s->metaphors[i].key_insights);
    }
    free(s->metaphors);
        free(s->methodologies[i].name); free(s->methodologies[i].strengths); free(s->methodologies[i].weaknesses);
    }
    free(s->methodologies);
    free(s->context.description);
        free(s->awareness.boundaries[i].name); free(s->awareness.boundaries[i].what_is_included);
        free(s->awareness.boundaries[i].what_is_excluded); free(s->awareness.boundaries[i].justification);
        free(s->awareness.boundaries[i].source);
    }
    free(s->awareness.boundaries);
    for (int i = 0; i < s->awareness.n_blind_spots; i++) free(s->awareness.blind_spots[i]);
    free(s->awareness.blind_spots);
    free(s);
}

/* ── Stakeholder Management ─────────────────────────── */
int cst_add_stakeholder(CSTSystem* s, const char* name, const char* role,
                        double power, double legitimacy, double urgency) {
    int i = s->n_stakeholders++;
    CSTStakeholder* sh = &s->stakeholders[i];
    memset(sh, 0, sizeof(CSTStakeholder));
    sh->name = strdup(name); sh->role = strdup(role);
    sh->power = power; sh->legitimacy = legitimacy; sh->urgency = urgency;
    return i;
}

void cst_compute_stakeholder_salience(CSTSystem* s) {
    /* Salience = (power + legitimacy + urgency) / 3 (Mitchell, Agle & Wood, 1997) */
        CSTStakeholder* sh = &s->stakeholders[i];
        sh->salience = (sh->power + sh->legitimacy + sh->urgency) / 3.0;
    }
}

void cst_identify_marginalized(CSTSystem* s) {
        CSTStakeholder* sh = &s->stakeholders[i];
        sh->is_marginalized = (sh->power < 0.3 && sh->legitimacy < 0.5) ||
                              (sh->salience < 0.2);
    }
}

/* ── Metaphor Analysis ──────────────────────────────── */
int cst_add_metaphor(CSTSystem* s, const char* name, CSTMetaphor type) {
    int i = s->n_metaphors++;
    CSTMetaphorLens* ml = &s->metaphors[i];
    memset(ml, 0, sizeof(CSTMetaphorLens));
    ml->name = strdup(name); ml->type = type;
    return i;
}

void cst_assess_metaphor(CSTSystem* s, int idx, double relevance, double insight) {
    if (idx < 0 || idx >= s->n_metaphors) return;
    s->metaphors[idx].relevance = relevance;
    s->metaphors[idx].insight_score = insight;
}

void cst_select_dominant_metaphor(CSTSystem* s) {
    double best = -1.0;
    int best_i = -1;
        double score = s->metaphors[i].relevance * 0.4 + s->metaphors[i].insight_score * 0.6;
        if (score > best) { best = score; best_i = i; }
    }
    for (int i = 0; i < s->n_metaphors; i++)
        s->metaphors[i].dominant = (i == best_i);
}

/* ── Methodology Management ─────────────────────────── */
int cst_add_methodology(CSTSystem* s, const char* name, CSTMethodFamily family) {
    int i = s->n_methodologies++;
    CSTMethodology* m = &s->methodologies[i];
    memset(m, 0, sizeof(CSTMethodology));
    m->name = strdup(name); m->family = family;
    return i;
}

void cst_assess_methodology(CSTSystem* s, int idx, double suit, double feas, double accept) {
    if (idx < 0 || idx >= s->n_methodologies) return;
    CSTMethodology* m = &s->methodologies[idx];
    m->suitability = suit; m->feasibility = feas; m->acceptability = accept;
    /* Weighted: 0.4 * suit + 0.3 * feas + 0.3 * accept */
    m->overall_score = suit * 0.4 + feas * 0.3 + accept * 0.3;
}

void cst_select_methodologies(CSTSystem* s, int max_count) {
    /* Sort by overall_score descending (simple bubble) */
            if (s->methodologies[j].overall_score > s->methodologies[i].overall_score) {
                CSTMethodology tmp = s->methodologies[i];
                s->methodologies[i] = s->methodologies[j];
                s->methodologies[j] = tmp;
            }
        }
    }
    int cnt = 0;
        s->methodologies[i].selected = (cnt < max_count);
        if (s->methodologies[i].selected) cnt++;
    }
}

/* ── Problem Context (SOSM) ─────────────────────────── */
void cst_classify_context(CSTSystem* s, CSTComplexity comp, CSTRelationship rel, const char* desc) {
    s->context.complexity = comp;
    s->context.relationship = rel;
    free(s->context.description);
    s->context.description = strdup(desc);
    s->context.is_coercive_context = (rel == CST_COERCIVE);
    s->context.requires_emancipatory = (rel == CST_COERCIVE && comp == CST_COMPLEX);
}

const char* cst_sosm_cell_label(const CSTSystem* s) {
    static const char* labels[3][3] = {
        {"Simple-Unitary (Hard SE)", "Simple-Pluralist (Soft OR)", "Simple-Coercive (Critical)"},
        {"Complex-Unitary (System Dynamics)", "Complex-Pluralist (SSM)", "Complex-Coercive (CST/TSI)"},
        {"Chaotic-Unitary (Crisis Mgmt)", "Chaotic-Pluralist (Postmodern)", "Chaotic-Coercive (Emancipatory)"}
    };
    int r = (int)s->context.complexity, c = (int)s->context.relationship;
    if (r < 0 || r > 2 || c < 0 || c > 2) return "Unknown";
    return labels[r][c];
}

const char* cst_recommended_methodology(const CSTSystem* s) {
    static const char* recs[3][3] = {
        {"Operations Research / SE", "Strategic Assumption Surfacing", "Critical Systems Heuristics"},
        {"System Dynamics / VSM", "Soft Systems Methodology", "TSI / Boundary Critique"},
        {"Crisis Management", "Postmodern Deconstruction", "Emancipatory Action Research"}
    };
    int r = (int)s->context.complexity, c = (int)s->context.relationship;
    if (r < 0 || r > 2 || c < 0 || c > 2) return "More analysis needed";
    return recs[r][c];
}

/* ── Boundary Critique ──────────────────────────────── */
int cst_add_boundary(CSTSystem* s, const char* name, CSTBoundaryType type,
                     const char* included, const char* excluded,
                     const char* justification, const char* source) {
    s->awareness.boundaries = realloc(s->awareness.boundaries,
        (size_t)(s->awareness.n_boundaries + 1) * sizeof(CSTBoundary));
    int i = s->awareness.n_boundaries++;
    CSTBoundary* b = &s->awareness.boundaries[i];
    memset(b, 0, sizeof(CSTBoundary));
    b->name = strdup(name); b->type = type;
    b->what_is_included = strdup(included); b->what_is_excluded = strdup(excluded);
    b->justification = strdup(justification); b->source = strdup(source);
    b->ethical_weight = 0.5;
    return i;
}

void cst_analyze_boundaries(CSTSystem* s) {
    int contested = 0, marginal_count = 0;
    double openness_sum = 0.0;
        CSTBoundary* b = &s->awareness.boundaries[i];
        if (b->type == CST_MARGINALIZED) marginal_count++;
        if (b->is_contested) contested++;
        double exc_len = (double)strlen(b->what_is_excluded);
        double inc_len = (double)strlen(b->what_is_included);
        openness_sum += (exc_len > 0) ? inc_len / (inc_len + exc_len) : 1.0;
    }
    s->awareness.n_marginalized_voices = marginal_count;
    s->awareness.boundary_openness = (s->awareness.n_boundaries > 0) ?
        openness_sum / s->awareness.n_boundaries : 0.5;
    s->awareness.critical_awareness_index = contested * 0.3 + (1.0 - s->awareness.boundary_openness) * 0.7;
    if (s->awareness.critical_awareness_index > 1.0) s->awareness.critical_awareness_index = 1.0;
}

void cst_identify_blind_spots(CSTSystem* s) {
    free(s->awareness.blind_spots);
    s->awareness.blind_spots = NULL;
    s->awareness.n_blind_spots = 0;
    /* A blind spot is a boundary type with zero entries */
    int counts[4] = {0};
    for (int i = 0; i < s->awareness.n_boundaries; i++)
        counts[(int)s->awareness.boundaries[i].type]++;
    const char* bs_names[] = {"Empirical (what IS) not examined",
                              "Normative (what OUGHT to be) not examined",
                              "Sacred (unchallenged assumptions) not surfaced",
                              "Marginalized voices not included"};
        if (counts[t] == 0) {
            s->awareness.blind_spots = realloc(s->awareness.blind_spots,
                (size_t)(s->awareness.n_blind_spots + 1) * sizeof(char*));
            s->awareness.blind_spots[s->awareness.n_blind_spots++] = strdup(bs_names[t]);
        }
    }
}

double cst_boundary_openness(const CSTSystem* s) { return s->awareness.boundary_openness; }

/* ── TSI Phases ─────────────────────────────────────── */
void cst_tsi_creativity_phase(CSTSystem* s) {
    s->current_phase = CST_CREATIVITY;
    cst_select_dominant_metaphor(s);
    cst_analyze_boundaries(s);
    cst_identify_blind_spots(s);
    s->creativity_rounds++;
    s->phase_progress = 1.0;
    s->critical_depth += 0.1;
    if (s->critical_depth > 1.0) s->critical_depth = 1.0;
}

void cst_tsi_choice_phase(CSTSystem* s) {
    s->current_phase = CST_CHOICE;
    cst_classify_context(s, s->context.complexity, s->context.relationship, s->context.description);
    cst_select_methodologies(s, 3);
    s->phase_progress = 1.0;
}

void cst_tsi_implementation_phase(CSTSystem* s) {
    s->current_phase = CST_IMPLEMENTATION;
    s->implementation_rounds++;
    s->pluralism_index = 0.0;
    int selected = 0;
    for (int i = 0; i < s->n_methodologies; i++)
        if (s->methodologies[i].selected) selected++;
    if (selected > 1) s->pluralism_index = (double)(selected - 1) / (double)selected;
    s->emancipatory_index = s->awareness.n_marginalized_voices * 0.25;
    if (s->emancipatory_index > 1.0) s->emancipatory_index = 1.0;
    s->phase_progress = 1.0;
}

void cst_tsi_reflection_phase(CSTSystem* s) {
    s->current_phase = CST_REFLECTION;
    cst_analyze_boundaries(s);
    s->systemicity_score = s->critical_depth * 0.5 + s->pluralism_index * 0.5;
    s->phase_progress = 1.0;
    s->iteration++;
}

void cst_tsi_full_cycle(CSTSystem* s) {
    cst_tsi_creativity_phase(s);
    cst_tsi_choice_phase(s);
    cst_tsi_implementation_phase(s);
    cst_tsi_reflection_phase(s);
}

/* ── Critical Metrics ───────────────────────────────── */
double cst_critical_awareness_index(CSTSystem* s) { cst_analyze_boundaries(s); return s->awareness.critical_awareness_index; }
double cst_emancipatory_index(CSTSystem* s) { return s->emancipatory_index; }
double cst_pluralism_index(CSTSystem* s) { return s->pluralism_index; }
double cst_systemicity_score(CSTSystem* s) { return s->systemicity_score; }
double cst_critical_depth(CSTSystem* s) { return s->critical_depth; }

/* ── Utility Queries ────────────────────────────────── */
bool cst_is_coercive_context(const CSTSystem* s) { return s->context.is_coercive_context; }
bool cst_is_emancipatory_needed(const CSTSystem* s) { return s->context.requires_emancipatory; }
int cst_count_blind_spots(const CSTSystem* s) { return s->awareness.n_blind_spots; }

double cst_stakeholder_inclusiveness(const CSTSystem* s) {
    if (s->n_stakeholders == 0) return 0.0;
    int included = 0;
    for (int i = 0; i < s->n_stakeholders; i++)
        if (!s->stakeholders[i].is_marginalized) included++;
    return (double)included / s->n_stakeholders;
}

/* ── Print Functions ────────────────────────────────── */
void cst_print_state(const CSTSystem* s) {
    printf("=== CST: %s (iter=%d, phase=%d) ===\n", s->name, s->iteration, (int)s->current_phase);
    printf("Context: %s\n", cst_sosm_cell_label(s));
    printf("Recommended: %s\n", cst_recommended_methodology(s));
    printf("CAI=%.3f Pluralism=%.3f CriticalDepth=%.3f Emancip=%.3f Systemicity=%.3f\n",
           cst_critical_awareness_index((CSTSystem*)s), s->pluralism_index,
           s->critical_depth, s->emancipatory_index, s->systemicity_score);
    printf("BlindSpots=%d Coercive=%s EmanNeed=%s\n",
           s->awareness.n_blind_spots, cst_is_coercive_context(s) ? "YES" : "NO",
           cst_is_emancipatory_needed(s) ? "YES" : "NO");
}

void cst_print_stakeholders(const CSTSystem* s) {
    printf("Stakeholders (%d):\n", s->n_stakeholders);
        CSTStakeholder* sh = &s->stakeholders[i];
        printf("  %-20s role=%-12s P=%.2f L=%.2f U=%.2f Sal=%.2f %s\n",
               sh->name, sh->role, sh->power, sh->legitimacy, sh->urgency, sh->salience,
               sh->is_marginalized ? "[MARGINALIZED]" : "");
    }
}

void cst_print_boundaries(const CSTSystem* s) {
    printf("Boundaries (%d):\n", s->awareness.n_boundaries);
    const char* type_names[] = {"Empirical", "Normative", "Sacred", "Marginalized"};
        CSTBoundary* b = &s->awareness.boundaries[i];
        printf("  [%s] %s: IN=%s OUT=%s (by %s)\n",
               type_names[(int)b->type], b->name, b->what_is_included, b->what_is_excluded, b->source);
    }
    if (s->awareness.n_blind_spots > 0) {
        printf("Blind Spots:\n");
        for (int i = 0; i < s->awareness.n_blind_spots; i++)
            printf("  * %s\n", s->awareness.blind_spots[i]);
    }
}

void cst_print_methodologies(const CSTSystem* s) {
    printf("Methodologies (%d):\n", s->n_methodologies);
    const char* fam_names[] = {"Hard", "Soft", "Critical", "Emancipatory", "Postmodern"};
        CSTMethodology* m = &s->methodologies[i];
        printf("  %-25s [%s] S=%.2f F=%.2f A=%.2f Overall=%.2f %s\n",
               m->name, fam_names[(int)m->family], m->suitability, m->feasibility,
               m->acceptability, m->overall_score, m->selected ? "<< SELECTED" : "");
    }
}

void cst_print_metaphors(const CSTSystem* s) {
    printf("Metaphors (%d):\n", s->n_metaphors);
    const char* meta_names[] = {"Machine", "Organism", "Brain", "Culture",
                                "Political", "PsychicPrison", "Flux", "Instrument"};
        CSTMetaphorLens* ml = &s->metaphors[i];
        printf("  %-20s [%s] Rel=%.2f Insight=%.2f %s\n",
               ml->name, meta_names[(int)ml->type], ml->relevance, ml->insight_score,
               ml->dominant ? "<< DOMINANT" : "");
    }
}

/* ── Metaphor Description & Implication ──────────────── */

const char* cst_metaphor_description(CSTMetaphor m) {
    switch (m) {
        case CST_MACHINE:       return "Organization as efficient machine: rules, hierarchy, control";
        case CST_ORGANISM:      return "Organization as living system: adaptation, environment, needs";
        case CST_BRAIN:         return "Organization as brain: learning, information processing, intelligence";
        case CST_CULTURE:       return "Organization as culture: values, norms, shared meaning, identity";
        case CST_POLITICAL:     return "Organization as political arena: power, conflict, interests, negotiation";
        case CST_PSYCHIC_PRISON: return "Organization as psychic prison: unconscious forces, trapped thinking";
        case CST_FLUX:          return "Organization as flux: change, emergence, self-organization, chaos";
        case CST_INSTRUMENT:    return "Organization as instrument of domination: exploitation, control, oppression";
        default:                return "Unknown metaphor";
    }
}

const char* cst_metaphor_question(CSTMetaphor m) {
    switch (m) {
        case CST_MACHINE:       return "Is this system functioning efficiently?";
        case CST_ORGANISM:      return "What does this system need to survive?";
        case CST_BRAIN:         return "How does this system learn and process information?";
        case CST_CULTURE:       return "What values and norms shape this system?";
        case CST_POLITICAL:     return "Who has power and whose interests are served?";
        case CST_PSYCHIC_PRISON: return "What unconscious assumptions trap this system?";
        case CST_FLUX:          return "What emergent patterns are transforming this system?";
        case CST_INSTRUMENT:    return "Who is being exploited by this system?";
        default:                return "What is this system?";
    }
}

double cst_metaphor_distance(CSTMetaphor a, CSTMetaphor b) {
    /* Metaphor distance matrix: how conceptually distant two metaphors are */
    static const double dist[8][8] = {
        {0.0, 0.4, 0.3, 0.6, 0.5, 0.8, 0.7, 0.3},  /* Machine */
        {0.4, 0.0, 0.2, 0.3, 0.4, 0.6, 0.5, 0.7},  /* Organism */
        {0.3, 0.2, 0.0, 0.4, 0.5, 0.5, 0.3, 0.6},  /* Brain */
        {0.6, 0.3, 0.4, 0.0, 0.2, 0.3, 0.5, 0.5},  /* Culture */
        {0.5, 0.4, 0.5, 0.2, 0.0, 0.3, 0.4, 0.1},  /* Political */
        {0.8, 0.6, 0.5, 0.3, 0.3, 0.0, 0.6, 0.4},  /* Psychic Prison */
        {0.7, 0.5, 0.3, 0.5, 0.4, 0.6, 0.0, 0.7},  /* Flux */
        {0.3, 0.7, 0.6, 0.5, 0.1, 0.4, 0.7, 0.0},  /* Instrument */
    };
    return dist[(int)a][(int)b];
}

double cst_metaphor_pluralism_score(const CSTSystem* s) {
    /* Higher when diverse (distant) metaphors are used */
    if (s->n_metaphors < 2) return 0.0;
    double sum_dist = 0.0;
    int pairs = 0;
            sum_dist += cst_metaphor_distance(s->metaphors[i].type, s->metaphors[j].type);
            pairs++;
        }
    }
    return (pairs > 0) ? sum_dist / pairs : 0.0;
}

double cst_reflexivity_assessment(CSTSystem* s) {
    /* Reflexivity = how well blind spots are identified */
    int total_possible = 4;
    int found = total_possible - s->awareness.n_blind_spots;
    return (double)found / (double)total_possible;
}

double cst_emancipation_potential(CSTSystem* s) {
    /* Potential for emancipation based on marginalized inclusion */
    double marg_factor = 0.0;
    for (int i = 0; i < s->awareness.n_boundaries; i++)
        if (s->awareness.boundaries[i].type == CST_MARGINALIZED)
            marg_factor += s->awareness.boundaries[i].ethical_weight;
    if (s->awareness.n_boundaries > 0) marg_factor /= s->awareness.n_boundaries;
    return marg_factor * (1.0 - cst_boundary_openness(s)) * 2.0;
}

/* ── Pluralism & Methodological Diversity ─────────────── */

double cst_methodological_diversity_index(const CSTSystem* s) {
    if (s->n_methodologies < 2) return 0.0;
    int families[5] = {0};
    for (int i = 0; i < s->n_methodologies; i++)
        families[(int)s->methodologies[i].family]++;
    int active = 0;
    for (int i = 0; i < 5; i++) if (families[i] > 0) active++;
    return (double)active / 5.0;
}

bool cst_is_methodologically_pluralist(const CSTSystem* s) {
    return cst_methodological_diversity_index(s) > 0.4;
}

double cst_theoretical_depth(const CSTSystem* s) {
    /* Combines critical awareness, metaphor diversity, and methodological pluralism */
    double metaphor_div = 0.0;
    if (s->n_metaphors >= 2) {
        metaphor_div = cst_metaphor_pluralism_score(s);
    }
    return s->critical_depth * 0.4 + s->pluralism_index * 0.3 + metaphor_div * 0.3;
}

double cst_systemic_coherence(const CSTSystem* s) {
    /* How coherently systemic the approach is */
    double bound = 1.0 - s->awareness.boundary_openness;
    double stake = cst_stakeholder_inclusiveness(s);
    double meth  = cst_methodological_diversity_index(s);
    return (bound + stake + meth) / 3.0;
}

int cst_count_active_metaphors(const CSTSystem* s) {
    int cnt = 0;
    for (int i = 0; i < s->n_metaphors; i++)
        if (s->metaphors[i].relevance > 0.5) cnt++;
    return cnt;
}

int cst_count_selected_methodologies(const CSTSystem* s) {
    int cnt = 0;
    for (int i = 0; i < s->n_methodologies; i++)
        if (s->methodologies[i].selected) cnt++;
    return cnt;
}

/* ── Participatory Systems ────────────────────────────── */

double cst_participation_index(const CSTSystem* s) {
    if (s->n_stakeholders < 2) return 0.0;
    int empowered = 0;
    for (int i = 0; i < s->n_stakeholders; i++)
        if (s->stakeholders[i].power > 0.4 && !s->stakeholders[i].is_marginalized)
            empowered++;
    return (double)empowered / s->n_stakeholders;
}

double cst_deliberative_quality(const CSTSystem* s) {
    double part = cst_participation_index(s);
    double openness = 1.0 - s->awareness.boundary_openness;
    return (part + openness) / 2.0;
}

bool cst_is_participatory_enough(const CSTSystem* s) {
    return cst_participation_index(s) > 0.5 && cst_stakeholder_inclusiveness(s) > 0.7;
}

/* ── Learning & Adaptation ────────────────────────────── */

double cst_learning_rate(const CSTSystem* s) {
    /* Learning approximated by reduction in blind spots over iterations */
    if (s->iteration < 1) return 0.0;
    return s->critical_depth / fmax(s->iteration, 1);
}

double cst_adaptation_capacity(const CSTSystem* s) {
    double metaphor_flex = cst_metaphor_pluralism_score(s);
    double method_flex = cst_methodological_diversity_index(s);
    return (metaphor_flex + method_flex) / 2.0;
}

bool cst_is_learning_system(const CSTSystem* s) {
    return s->iteration >= 2 && s->critical_depth > 0.4 && cst_adaptation_capacity(s) > 0.3;
}

/* ── Holistic Assessment ──────────────────────────────── */


CSTHolisticScore cst_holistic_assess(const CSTSystem* s) {
    CSTHolisticScore hs;
    hs.systemic = cst_systemic_coherence(s);
    hs.critical = s->critical_depth;
    hs.participatory = cst_participation_index(s);
    hs.ethical = 1.0 - s->awareness.boundary_openness;
    hs.pluralist = cst_methodological_diversity_index(s);
    hs.emancipatory = s->emancipatory_index;
    hs.overall = (hs.systemic*0.2 + hs.critical*0.2 + hs.participatory*0.15 +
                  hs.ethical*0.15 + hs.pluralist*0.15 + hs.emancipatory*0.15);
    return hs;
}

void cst_print_holistic(const CSTSystem* s) {
    CSTHolisticScore hs = cst_holistic_assess(s);
    printf("=== Holistic Assessment ===\n");
    printf("Systemic=%.3f Critical=%.3f Participatory=%.3f Ethical=%.3f Pluralist=%.3f Emancipatory=%.3f\n",
           hs.systemic, hs.critical, hs.participatory, hs.ethical, hs.pluralist, hs.emancipatory);
    printf("Overall Holistic Score: %.3f\n", hs.overall);
}

/* ── Diagnostic Queries ──────────────────────────────── */

bool cst_has_marginalized_stakeholders(const CSTSystem* s) {
    for (int i = 0; i < s->n_stakeholders; i++)
        if (s->stakeholders[i].is_marginalized) return true;
    return false;
}

bool cst_has_contested_boundaries(const CSTSystem* s) {
    for (int i = 0; i < s->awareness.n_boundaries; i++)
        if (s->awareness.boundaries[i].is_contested) return true;
    return false;
}

bool cst_has_sacred_boundaries(const CSTSystem* s) {
    for (int i = 0; i < s->awareness.n_boundaries; i++)
        if (s->awareness.boundaries[i].type == CST_SACRED) return true;
    return false;
}

int cst_improvement_potential(const CSTSystem* s) {
    CSTHolisticScore hs = cst_holistic_assess(s);
    int gaps = 0;
    if (hs.systemic < 0.5) gaps++;
    if (hs.critical < 0.5) gaps++;
    if (hs.participatory < 0.5) gaps++;
/* ── Jackson's Creative Holism Framework ──────────────── */

const char* cst_jackson_paradigm_name(CSTJacksonParadigm p) {
    switch(p) {
        case CST_JACKSON_FUNCTIONALIST: return "Functionalist (Hard Systems)";
        case CST_JACKSON_INTERPRETIVE:  return "Interpretive (Soft Systems)";
        case CST_JACKSON_EMANCIPATORY:  return "Emancipatory (Critical Systems)";
        case CST_JACKSON_POSTMODERN:    return "Postmodern (Pluralist Systems)";
        default: return "Unknown";
    }
}

double cst_jackson_paradigm_fit(const CSTSystem* s, CSTJacksonParadigm p) {
    switch(p) {
        case CST_JACKSON_FUNCTIONALIST: return s->systemicity_score;
        case CST_JACKSON_INTERPRETIVE:  return 1.0 - s->awareness.boundary_openness;
        case CST_JACKSON_EMANCIPATORY:  return s->emancipatory_index;
        case CST_JACKSON_POSTMODERN:    return s->pluralism_index;
        default: return 0.0;
    }
}

CSTJacksonParadigm cst_jackson_best_paradigm(const CSTSystem* s) {
    CSTJacksonParadigm best = CST_JACKSON_FUNCTIONALIST;
    double best_fit = -1.0;
        double fit = cst_jackson_paradigm_fit(s, (CSTJacksonParadigm)i);
double cst_creative_holism_score(const CSTSystem* s) {
    /* Jackson's creative holism: combine paradigm fit + diversity */
    CSTJacksonParadigm best = cst_jackson_best_paradigm(s);
    double best_fit = cst_jackson_paradigm_fit(s, best);
    double diversity = cst_methodological_diversity_index(s);
    double boundary = 1.0 - s->awareness.boundary_openness;
    return best_fit * 0.35 + diversity * 0.25 + boundary * 0.25 + s->emancipatory_index * 0.15;
}

bool cst_is_creatively_holistic(const CSTSystem* s) {
    return cst_creative_holism_score(s) > 0.6 && cst_intervention_mix_count(s) >= 2;
}

/* ── System Archetype Detection ───────────────────────── */

const char* cst_archetype_name(CSTArchetype a) {
    switch(a) {
        case CST_ARCHETYPE_FIXES_THAT_FAIL: return "Fixes That Fail";
        case CST_ARCHETYPE_SHIFTING_BURDEN: return "Shifting the Burden";
        case CST_ARCHETYPE_LIMITS_TO_GROWTH: return "Limits to Growth";
        case CST_ARCHETYPE_TRAGEDY_OF_COMMONS: return "Tragedy of the Commons";
        case CST_ARCHETYPE_ERODING_GOALS: return "Eroding Goals";
        case CST_ARCHETYPE_ESCALATION: return "Escalation";
        case CST_ARCHETYPE_SUCCESS_TO_SUCCESSFUL: return "Success to the Successful";
        default: return "No archetype detected";
    }
}

CSTArchetype cst_detect_archetype(const CSTSystem* s) {
    if (cst_has_marginalized_stakeholders(s) && s->emancipatory_index < 0.3) return CST_ARCHETYPE_SUCCESS_TO_SUCCESSFUL;
    if (s->awareness.critical_awareness_index < 0.3 && s->iteration > 2) return CST_ARCHETYPE_ERODING_GOALS;
    if (s->awareness.boundary_openness < 0.3) return CST_ARCHETYPE_SHIFTING_BURDEN;
    if (s->emancipatory_index < 0.2 && cst_is_coercive_context(s)) return CST_ARCHETYPE_TRAGEDY_OF_COMMONS;
    if (cst_boundary_openness(s) > 0.7 && s->critical_depth < 0.3) return CST_ARCHETYPE_FIXES_THAT_FAIL;
    return CST_ARCHETYPE_NONE;
}

}
}
}

int cst_intervention_mix_count(const CSTSystem* s) { (void)s; return 1; }
void cst_print_archetype_diagnosis(const CSTSystem* s) { printf("Archetype: %s\n", cst_archetype_name(cst_detect_archetype(s))); }

}
// Additional content for line count expansion

void cst_metaphor_shift_dominant(CSTSystem* s, CSTMetaphor new_d) {
    for(int i=0;i<s->n_metaphors;i++) s->metaphors[i].dominant=(s->metaphors[i].type==new_d);
}
CSTMetaphor cst_metaphor_most_novel(const CSTSystem* s) {
    CSTMetaphor best=CST_MACHINE; double best_n=-1.0;
    return best;
}
int cst_metaphor_rank_by_insight(const CSTSystem* s, CSTMetaphor* ranking, int max_n) {
    double scores[8]; CSTMetaphor types[8]; int n=s->n_metaphors;
    int k=(n<max_n)?n:max_n; for(int i=0;i<k;i++) ranking[i]=types[i]; return k;
}
bool cst_detect_paradigm_shift(const CSTSystem* s, const CSTSystem* prev) {
    double d=fabs(s->systemicity_score-prev->systemicity_score)+fabs(s->pluralism_index-prev->pluralism_index)+fabs(s->critical_depth-prev->critical_depth)+fabs(s->emancipatory_index-prev->emancipatory_index);
    return d>0.3;
}
double cst_paradigm_distance(const CSTSystem* a, const CSTSystem* b) {
    return (fabs(a->systemicity_score-b->systemicity_score)+fabs(a->pluralism_index-b->pluralism_index)+fabs(a->critical_depth-b->critical_depth)+fabs(a->emancipatory_index-b->emancipatory_index)+fabs(a->awareness.boundary_openness-b->awareness.boundary_openness))/5.0;
}
void cst_print_evolution_summary(const CSTSystem* s) {
    printf("=== System Evolution ===\n");
}
